# Cognito & Tesla OAuth settings
VITE_AWS_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=<your_user_pool_id>
VITE_COGNITO_CLIENT_ID=<your_app_client_id>
VITE_COGNITO_DOMAIN=<your_cognito_domain>

# Amazon Location Service
VITE_MAP_STYLE_URL=<amazon_location_style_descriptor_url>

# Optional – back-end API base (leave blank for same origin)
VITE_API_URL=

VITE_WS_URL=wss://your-websocket-endpoint