# Tesla OAuth Configuration
TESLA_CLIENT_ID=your_tesla_client_id_here
TESLA_CLIENT_SECRET=your_tesla_client_secret_here

# Domain Configuration
DOMAIN_NAME=tesla-fleet.example.com

# Cognito Domain Prefix (subdomain for Cognito authentication)
COGNITO_DOMAIN_PREFIX=my-awesome-fleet

# AWS Configuration
AWS_PROFILE=bonsai
AWS_DEFAULT_REGION=us-west-2

# Note: The deployment script will automatically use the 'bonsai' profile
# Make sure your ~/.aws/credentials file contains the [bonsai] profile

# Optional: Custom Configuration
# ECS_CPU=1024
# ECS_MEMORY=2048
# DYNAMODB_BILLING_MODE=PAY_PER_REQUEST
# KINESIS_SHARD_COUNT=1